{
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
      ]
    },
    {
      "source": "/forest/(.*\\.(?:gltf|glb|bin|png|jpg))",
      "headers": [
        { "key": "Cache-Control", "value": "public,max-age=604800" }
      ]
    }
  ]
}
